# Copy to scripts/docker/.env and edit as needed.
# Compose auto-loads .env from the directory of the compose file.
#
# IMPORTANT: use absolute paths. Some Docker installs (snap, rootless with
# private home) resolve `~` and even `$HOME` to a confined dir.

# Where openpi caches downloaded gs:// checkpoints (default: ~/.cache/openpi).
OPENPI_DATA_HOME=/home/yinpeidai/.cache/openpi

# Where HuggingFace caches LeRobot datasets and tokenizers.
HF_HOME=/home/yinpeidai/.cache/huggingface

# Optional: which GPUs to expose. "all", "0", "0,1", etc.
NVIDIA_VISIBLE_DEVICES=all

# Run as host user so files written into bind-mounts (./checkpoints, ./wandb,
# ./assets) aren't owned by root. Get yours with `id -u` / `id -g`.
HOST_UID=1000
HOST_GID=1000

# Training selection. The default CMD does:
#   python scripts/train.py $TRAIN_CONFIG --exp-name=$EXP_NAME $TRAIN_ARGS
# Override TRAIN_CMD to swap the trainer entirely (e.g. PyTorch).
TRAIN_CONFIG=pi05_libero_debug
EXP_NAME=debug
# TRAIN_ARGS=--fsdp-devices=2 --overwrite
# TRAIN_CMD=torchrun --standalone --nnodes=1 --nproc_per_node=2 scripts/train_pytorch.py pi05_libero_debug --exp_name=debug

# WandB. Use offline by default to avoid surprises; flip to online once you have a key wired up.
WANDB_MODE=offline
# WANDB_API_KEY=...

# JAX: fraction of GPU memory the JAX runtime is allowed to preallocate.
XLA_PYTHON_CLIENT_MEM_FRACTION=0.9
